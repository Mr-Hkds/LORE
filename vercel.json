{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/stories/add", "destination": "/api/stories" },
    { "source": "/api/stories/publish", "destination": "/api/stories" },
    { "source": "/api/stories/react", "destination": "/api/stories" },
    { "source": "/api/stories/:id", "destination": "/api/stories" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
